# =============================================================================
# Synergine App — Environment Variables
# =============================================================================
# Copy to .env:  cp env.example .env

# --- App ---
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:5173

# --- Better Auth ---
BETTER_AUTH_SECRET=synergine-dev-secret-change-in-production
BETTER_AUTH_URL=http://localhost:3001

# --- Database (SQLite via libSQL) ---
DATABASE_URL=file:local.db

# --- Infrastructure (Docker services) ---
# Start with: docker compose up -d
# Add profiles: --profile search --profile monitoring --profile dashboard --profile gateway

# SurrealDB — Multi-model database (graph + vector + doc + FTS)
# Provides: ns=synergine, db=main by default
SURREALDB_USER=root
SURREALDB_PASS=synergine
SURREALDB_PORT=8000
SURREALDB_URL=http://localhost:8000
SURREAL_URL=http://localhost:8000
SURREAL_NS=synergine
SURREAL_DB=main
SURREAL_USER=root
SURREAL_PASS=root

# Dragonfly — Redis-compatible cache (25x faster than Redis)
# Single-threaded for predictable latency, 1GB default maxmemory
DRAGONFLY_PASS=synergine
DRAGONFLY_URL=redis://:synergine@localhost:6379

# NATS — Cloud-native messaging with JetStream
# Provides pub/sub, streaming, and durable message storage
NATS_URL=nats://localhost:4222
NATS_PORT=4222
NATS_MONITOR_PORT=8222

# Meilisearch — Full-text search engine
# Start with: docker compose --profile search up -d
# Features: typo tolerance, faceted search, ranking rules
MEILI_MASTER_KEY=synergine-meili-key
MEILI_KEY=synergine-meili-key
MEILI_URL=http://localhost:7700
MEILI_PORT=7700
MEILI_ENV=development

# Langfuse — LLM observability for AI/Agent workflows
# Start with: docker compose --profile monitoring up -d
# Provides: prompt versioning, cost tracking, A/B testing
LANGFUSE_DB_USER=langfuse
LANGFUSE_DB_PASS=langfuse-dev
LANGFUSE_SECRET=synergine-langfuse-secret-change-in-prod
LANGFUSE_SALT=synergine-salt-change-in-prod
LANGFUSE_PORT=3100
LANGFUSE_URL=http://localhost:3100

# Uptime Kuma — Unified monitoring dashboard (--profile monitoring)
# Monitors: HTTP endpoints, Ping, DNS, SMTP
UPTIME_KUMA_PORT=3200
UPTIME_KUMA_URL=http://localhost:3200

# Dozzle — Real-time Docker container logs (--profile dashboard)
# Web UI for viewing and filtering logs from all running containers
DOZZLE_PORT=9999

# Caddy — Reverse proxy / API gateway (--profile gateway)
# Used for production-like setup with HTTPS and routing
# Configure in: infra/Caddyfile

# --- Payments (Polar) ---
# Get token from https://polar.sh
POLAR_ACCESS_TOKEN=

# --- Email (Resend) ---
# Get API key from https://resend.com (starts with "re_")
RESEND_API_KEY=
