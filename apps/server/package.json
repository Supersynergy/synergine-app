{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.mjs"
  },
  "dependencies": {
    "@synergine-app/auth": "workspace:*",
    "@synergine-app/db": "workspace:*",
    "@synergine-app/env": "workspace:*",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "hono": "^4.8.2",
    "zod": "catalog:",
    "ioredis": "^5.6.1",
    "nats": "^2.28.0",
    "surrealdb": "^2.0.0"
  },
  "devDependencies": {
    "@synergine-app/config": "workspace:*",
    "@types/bun": "catalog:",
    "tsdown": "^0.16.5",
    "typescript": "^5"
  }
}
